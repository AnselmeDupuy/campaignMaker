<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:controller="com.example.CampaignManager.controller.MainController" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <BorderPane fx:id="mainLayout" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <VBox fx:id="topContainer" prefHeight="70.0" prefWidth="100.0" BorderPane.alignment="CENTER">
               <children>
                  <MenuBar fx:id="menuBar">
                    <menus>
                      <Menu mnemonicParsing="false" text="File">
                        <items>
                          <MenuItem fx:id="menuNewCampaign" mnemonicParsing="false" text="New Campaign" />
                              <MenuItem fx:id="menuLoadCampaign" mnemonicParsing="false" text="Load Campaign" />
                              <MenuItem fx:id="menuSaveCampaign" mnemonicParsing="false" text="Save Campaign" />
                              <MenuItem fx:id="menuExit" mnemonicParsing="false" text="Exit" />
                        </items>
                      </Menu>
                      <Menu mnemonicParsing="false" text="Database">
                        <items>
                          <MenuItem fx:id="menuLoadDatabase" mnemonicParsing="false" text="Load Database" />
                              <MenuItem fx:id="menuRefreshDatabase" mnemonicParsing="false" text="Refresh Database" />
                              <MenuItem fx:id="menuSaveMonster" mnemonicParsing="false" text="Add Monster" />
                              <MenuItem fx:id="menuDeleteMonster" mnemonicParsing="false" text="Remove Monster" />
                              <MenuItem fx:id="menuSaveItem" mnemonicParsing="false" text="Add Item" />
                              <MenuItem fx:id="menuDeleteItem" mnemonicParsing="false" text="Remove Item" />
                              <MenuItem fx:id="menuSaveSpell" mnemonicParsing="false" text="Add Spell" />
                              <MenuItem fx:id="menuDeleteSpell" mnemonicParsing="false" text="Remove Spell" />
                        </items>
                      </Menu>
                        <Menu mnemonicParsing="false" text="Campaign">
                           <items>
                              <MenuItem fx:id="menuSaveEncounter" mnemonicParsing="false" text="Create Encounter" />
                              <MenuItem fx:id="menuDeleteEncounter" mnemonicParsing="false" text="Remove Encounter" />
                              <MenuItem fx:id="menuLinkEncounter" mnemonicParsing="false" text="Link Encounter" />
                           </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Tools">
                           <items>
                              <MenuItem mnemonicParsing="false" text="Monster Editor" />
                              <MenuItem mnemonicParsing="false" text="Item Editor" />
                              <MenuItem mnemonicParsing="false" text="Spell Editor" />
                              <MenuItem mnemonicParsing="false" text="Campaign Editor" />
                           </items>
                        </Menu>
                        <Menu mnemonicParsing="false" text="Help">
                           <items>
                              <MenuItem mnemonicParsing="false" text="Preferences" />
                              <MenuItem mnemonicParsing="false" text="Help" />
                              <MenuItem mnemonicParsing="false" text="Github" />
                              <MenuItem mnemonicParsing="false" text="New" />
                           </items>
                        </Menu>
                    </menus>
                  </MenuBar>
                  <ToolBar fx:id="toolBar" prefHeight="40.0" prefWidth="200.0">
                     <items>
                        <TextField fx:id="searchField" maxWidth="250.0" minWidth="200.0" prefWidth="250.0" promptText="Search..." />
                        <Button fx:id="btnNewMonster" mnemonicParsing="false" text="+ Monster" />
                        <Button fx:id="btnNewItem" mnemonicParsing="false" text="+ Item" />
                        <Button fx:id="btnNewSpell" mnemonicParsing="false" text="+ Spell" />
                        <Button fx:id="btnNewCampaign" mnemonicParsing="false" text="+ Campaign" />
                        <Button fx:id="btnNewEncounter" mnemonicParsing="false" text="+ Encounter" />
                     </items>
                  </ToolBar>
               </children>
            </VBox>
         </top>
         <center>
            <SplitPane fx:id="mainSplitPane" dividerPositions="0.2, 0.8" prefHeight="160.0" prefWidth="200.0" BorderPane.alignment="CENTER">
              <items>
                  <VBox prefHeight="200.0" prefWidth="50.0">
                     <children>
                        <Label text="Lib" />
                        <TreeView fx:id="navigationTree" minWidth="200.0" prefHeight="611.0" prefWidth="253.0" />
                     </children>
                  </VBox>
                  <TabPane fx:id="editorTabs" prefHeight="200.0" prefWidth="350.0" tabClosingPolicy="ALL_TABS">
                    <tabs>
                      <Tab fx:id="welcomeTab" text="welcome">
                        <content>
                          <AnchorPane fx:id="welcomePane" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="300.0" />
                        </content>
                      </Tab>
                    </tabs>
                  </TabPane>
                  <VBox fx:id="detailsPanel" prefHeight="200.0" prefWidth="100.0" spacing="8.0">
                     <children>
                        <Label fx:id="lblRelatedObjects" prefHeight="25.0" text="Related Objects" />
                        <ListView fx:id="relatedObjectsList" prefHeight="250.0" prefWidth="150.0" />
                        <Separator fx:id="separatorPreview" orientation="VERTICAL" prefHeight="50.0" />
                        <Label fx:id="lblPreview" prefHeight="25.0" text="Preview" />
                        <ScrollPane fx:id="previewScrollPane" prefHeight="200.0" prefWidth="150.0">
                          <content>
                            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="150.0" />
                          </content>
                        </ScrollPane>
                        <Separator fx:id="separatorNote" orientation="VERTICAL" prefHeight="50.0" />
                        <Label fx:id="lblNotes" prefHeight="25.0" text="Notes" />
                        <TextArea fx:id="notesArea" prefHeight="300.0" prefWidth="150.0" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
              </items>
            </SplitPane>
         </center>
         <bottom>
            <TextArea fx:id="consoleOutput" editable="false" maxHeight="80.0" prefHeight="80.0" prefWidth="1280.0" wrapText="true" BorderPane.alignment="CENTER" />
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
